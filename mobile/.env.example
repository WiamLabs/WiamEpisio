# © 2026 WiamApp. Powered by WiamLabs
# Copy to .env and fill in real values, then `npx expo start`.
# This file didn't exist before — the code was already expecting it
# (see the error message in lib/supabase.js) but nobody had written it.

# ── REQUIRED — app won't start without these three ──────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard
EXPO_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Uploads (photos, ID docs, voice messages) all go through the
# backend, never directly from the app to R2 — so no R2 vars are
# needed here at all. Cloudinary below is for portfolio/avatar
# images specifically, uploaded straight from the app.

# ── NOT CURRENTLY USED — safe to leave blank, no billing needed ──
# lib/api/places.js wraps Google Places Autocomplete, but no screen
# in the app actually imports it — it's unused code. The one screen
# that needs location (WorkerSafetyScreen, for GPS check-in/SOS) uses
# the phone's own free built-in GPS via expo-location instead, which
# needs no API key and no Google Cloud billing account at all.
# If address autocomplete ever gets wired into a real screen later,
# that's when this becomes worth setting up — not before.
EXPO_PUBLIC_GOOGLE_PLACES_KEY=

# ── Mapping (blueprint: Mapbox global + GhanaPost for GH) ──────
# Free public token from https://account.mapbox.com/
# Without this, Ghana still uses GhanaPostGPS; elsewhere falls back to device/OSM.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ── OPTIONAL — subscriptions via App Store/Play Store IAP ───────
# Only needed if you're testing Worker Pro purchases through
# RevenueCat. Leave blank to test everything else.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ── OPTIONAL — legacy image upload path ──────────────────────────
# Cloudinary appears in a couple of older upload helpers alongside
# the newer R2 pipeline. Leave blank unless something specifically
# breaks asking for it.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── DORMANT — not wired to any screen, safe to leave blank ───────
# lib/api/security.js has a verifyIdDocument() function that calls
# Smile Identity directly to auto-check a Ghana Card/Passport number
# against a government database. It exists in the code but no screen
# calls it yet — verification today is 100% manual admin review of
# the uploaded photos (web + app both feed the same queue). You do
# NOT need a Smile Identity account to test anything right now.
# Also worth knowing for later: this key is EXPO_PUBLIC_ (bundled
# into the app, extractable by anyone), which is fine for a dormant
# feature but should move server-side before it's ever wired up for
# real, so the API key isn't sitting in the public app bundle.
EXPO_PUBLIC_SMILE_IDENTITY_PARTNER_ID=
EXPO_PUBLIC_SMILE_IDENTITY_API_KEY=
EXPO_PUBLIC_SMILE_IDENTITY_ENV=sandbox
