# ============================================================
# WiamApp — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git — it contains secrets.
# ============================================================

# --- Database (Supabase Postgres) ---
# Full connection string for production (Render env -> Supabase Postgres pooler)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Individual params for local development:
DB_NAME=wiamlight
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Web App ---
# Public URL where the app is hosted (e.g. https://wiamapp.onrender.com)
APP_URL=
# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- Telegram Bot ---
# Bot token from @BotFather (REQUIRED for bot features)
BOT_TOKEN=
# Bot username without @ (e.g. WiamAppBot)
BOT_USERNAME=WiamAppBot
# Founder's Telegram ID — auto-assigned founder role on first /start
FOUNDER_TELEGRAM_ID=
# Telegram channel ID for showroom posts (e.g. -1001234567890)
CHANNEL_ID=
# Chat IDs for bot training and notifications
TRAINING_CHAT_ID=
NOTIFY_CHAT_ID=

# --- Google OAuth ---
# Google OAuth client ID for "Sign in with Google"
GOOGLE_CLIENT_ID=

# --- Paystack Payments (Ghana) ---
# Get keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Elite subscription plan code from Paystack dashboard
PAYSTACK_ELITE_PLAN_CODE=

# --- SMTP Email ---
# For email verification, password reset, and notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Cloudinary (image CDN — REQUIRED for avatars, covers, voice covers) ---
# Free tier is 25 monthly credits, plenty for early scale.
# Sign up: https://cloudinary.com/users/register/free
# Dashboard -> Account Details for the three values below.
# If any of these are missing in production the startup log will print
# "Cloudinary NOT configured" and every image upload will return 500.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Web Push Notifications (VAPID) ---
# Generate with: python generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:support@wiamapp.com

# Public support vs company email (must match how you run the inboxes)
# SUPPORT_EMAIL — users, privacy policy, Play Store, account help
# COMPANY_EMAIL — team accounts, QA/engineering, internal ops
SUPPORT_EMAIL=support@wiamapp.com
COMPANY_EMAIL=labs@wiamapp.com

# --- Payment Details (shown to users) ---
MOMO_NUMBER=
BANK_DETAILS=

# --- Redis (optional) ---
# For rate limiting. If not set, falls back to in-memory storage.
# REDIS_URL=redis://localhost:6379

# --- Play Integrity (Android anti-abuse hardening) ---
# Rollout step 1 (observe only): keep false/false
# Rollout step 2 (enforce verification): true/false
# Rollout step 3 (block trial without valid integrity): true/true
PLAY_INTEGRITY_ENFORCE=false
PLAY_INTEGRITY_REQUIRED_FOR_TRIAL=false

# Keep this true for production (Play-installed/recognized app only)
PLAY_INTEGRITY_REQUIRE_PLAY_RECOGNIZED=true
# Optional stricter check (recommended true later in rollout)
PLAY_INTEGRITY_REQUIRE_LICENSED=false

# Package name from Play Console (exact match)
# Example: com.wiam.app
PLAY_INTEGRITY_PACKAGE_NAME=<YOUR_ANDROID_PACKAGE_NAME>

# Optional audience claim expected in JWS token.
# Leave empty unless your token flow sets this consistently.
PLAY_INTEGRITY_AUDIENCE=

# Google certs endpoint for JWS verification (normally keep default)
PLAY_INTEGRITY_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# Allowed device verdicts (comma-separated)
# Recommended launch baseline:
PLAY_INTEGRITY_ALLOWED_DEVICE_VERDICTS=MEETS_DEVICE_INTEGRITY,MEETS_BASIC_INTEGRITY

# --- iOS integrity rollout ---
# false/false = observe mode
# true/false  = enforce verification endpoint but do not block trial
# true/true   = block trial unless iOS integrity check passes
IOS_INTEGRITY_ENFORCE=false
IOS_INTEGRITY_REQUIRED_FOR_TRIAL=false
IOS_INTEGRITY_AUDIENCE=
IOS_INTEGRITY_ISSUER=
IOS_INTEGRITY_JWKS_URL=
IOS_INTEGRITY_REQUIRE_JWT_SIGNATURE=false

# --- QA automation webhook (GitHub Actions -> QA dashboard) ---
# Set to a long random secret in Render + GitHub Secret QA_WEBHOOK_SECRET
QA_AUTOMATION_WEBHOOK_SECRET=
