# © 2026 WiamApp. Powered by WiamLabs
# backend/.env.example — copy to backend/.env and fill in real values.
# This file is generated by actually grepping every process.env.X
# reference in the backend code, so it should never drift from
# what the code really needs.

# ── REQUIRED — nothing in the backend works without these ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_service_role_key_from_supabase_dashboard
NODE_ENV=production
PORT=3000

# ── REQUIRED for any chat message to send (Section 5B) ────────
# You need AT LEAST ONE of these 5. More = more combined free
# quota and redundancy, since each provider has its own
# independent rate-limit pool. Zero configured = every chat
# message fails closed with "moderation unavailable" — this is
# intentional, not a bug. See backend/routes/chat.js for details
# and current free-tier setup links for each.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
# Fastest of the 5, 1M free tokens/day, no card required.
CEREBRAS_API_KEY=

# ── REQUIRED for the nightly cron jobs (Section 4B rankings/eligibility) ──
# Any long random string you generate yourself. Must match exactly
# what you configure on cron-job.org as the X-Cron-Secret header.
CRON_SECRET=

# ── REQUIRED for payments (Africa — Paystack) ─────────────────
PAYSTACK_SECRET_KEY=

# ── Stripe (worldwide) — code is ready; leave disabled until live ──
# Set PAYMENTS_STRIPE_ENABLED=true only after Stripe account + webhook are set.
PAYMENTS_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional testing override: paystack | stripe
# PAYMENTS_FORCE_PROVIDER=

# RevenueCat webhook signature verification (App Store/Play Store
# in-app subscription purchases)
REVENUECAT_WEBHOOK_SECRET=

# ── Email (WiamApp only — Brevo; Resend is for other WiamLabs products) ──
# https://app.brevo.com → SMTP & API → API keys
BREVO_API_KEY=
EMAIL_FROM=WiamApp <noreply@wiamapp.com>
# Password reset landing page (must be allowlisted in Supabase Auth → URL Configuration)
PASSWORD_RESET_REDIRECT_URL=https://wiamapp.com/reset-password

# ── REQUIRED for ID/document/portfolio file storage ────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=
# A second, PRIVATE R2 bucket for sensitive documents (ID photos,
# business registration certs) that should never be public —
# separate credentials from the public bucket above on purpose.
R2_PRIVATE_ACCESS_KEY=
R2_PRIVATE_SECRET_KEY=
R2_PRIVATE_BUCKET_NAME=
R2_PRIVATE_ENDPOINT=

# ── REQUIRED for currency display conversion (Section 3/5) ─────
OPEN_EXCHANGE_RATES_APP_ID=

# ── REQUIRED for WiaMid generation (Section 19) ─────────────────
WIAMID_SALT=

# ── Studio Founder proxy (wiamlabs-studio → this API) ─────────
# Same value as STUDIO_SERVICE_KEY on Studio hosting
STUDIO_SERVICE_KEY=
STUDIO_ACTOR_USER_ID=

# ── Telegram → Studio passwordless Founder (same pattern as WiamPass) ──
# Martin's Telegram numeric user id (same as WiamPass FOUNDER_TELEGRAM_ID)
FOUNDER_TELEGRAM_ID=
FOUNDER_EMAIL=founder@wiamapp.com
# Shared with WiamPass bot worker so @WiamPassBot can mint WiamApp Studio links
TELEGRAM_BOT_INTERNAL_SECRET=
