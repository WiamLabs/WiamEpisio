# Copy to .env.local and fill in real values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard

# Same Cloudinary account as the mobile app
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Your Express backend (Render) — needed for Spotlight posting,
# since that route runs AI moderation/admin-notification logic
# that a direct Supabase insert would skip entirely.
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
