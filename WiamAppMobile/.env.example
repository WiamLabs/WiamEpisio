# Copy to .env — used by Expo at bundle time (never commit .env with secrets).
# Physical phone + local server: use your PC LAN IP (not localhost).
# If you omit this on a real device in dev, the app uses https://api.wiamapp.com/api/v1

EXPO_PUBLIC_API_URL=https://episio.wiamlabs.com/api/v1

# Google Cloud project number used by Android Play Integrity token provider
# Example: 123456789012
EXPO_PUBLIC_PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER=

# Google Sign-In client IDs (from Google Cloud Console → OAuth client IDs).
# When unset, the in-app "Continue with Google" button shows a "Coming soon" toast
# instead of attempting the OAuth flow. Set at least the WEB client id for it
# to work in Expo Go; add the platform-specific ones for production builds.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
