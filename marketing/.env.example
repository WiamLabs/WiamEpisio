# Copy to .env.local and fill in real values.

# Your Express backend (Render) — Browse/Profile pages read public
# worker data from here. No auth needed, this site never logs
# anyone in.
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Same Supabase project, used ONLY for reading public, already-
# approved Spotlight posts and category lists directly — no auth,
# no writes, RLS already restricts these tables to public-safe rows.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard

# The Business portal is a separate internal Render service, proxied
# transparently under wiamapp.com/business/* — this is a SERVER-side
# var (no NEXT_PUBLIC_ prefix), the browser never sees it directly.
# Set to the business-web service's real Render URL, e.g.
# https://wiamapp-business-web.onrender.com
BUSINESS_ORIGIN=https://wiamapp-business-web.onrender.com
